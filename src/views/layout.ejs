<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        /* Thêm một chút CSS để menu đẹp hơn */
        .nav-link:hover { color: #ff4d7d !important; }
        .navbar-brand { font-weight: bold; color: #ff4d7d !important; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">

        <a class="navbar-brand" href="/">Dream Bakery 🥐</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">

                <li class="nav-item">
                    <a class="nav-link" href="/">Trang chủ</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/sanpham">Sản phẩm</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/giohang">
                        <i class="fa-solid fa-cart-shopping me-1"></i>Giỏ hàng
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/donhang">Đơn hàng</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/help">Trợ giúp</a>
                </li>

                <% if (typeof user !== 'undefined' && user) { %>
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-outline-warning btn-sm" href="/auth/logout">
                            <i class="fa-solid fa-right-from-bracket me-1"></i>Thoát (<%= user.HoVaTen %>)
                        </a>
                    </li>
                <% } else { %>
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-danger btn-sm" href="/auth/login" style="background-color: #ff4d7d; border: none;">
                            Đăng nhập
                        </a>
                    </li>
                <% } %>

            </ul>
        </div>

    </div>
</nav>

<div class="container mt-4 mb-5" style="min-height: 70vh;">
    <%- body %>
</div>

<footer class="text-center mt-5 py-4 bg-light border-top">
    <p class="m-0">&copy; 2026 Dream Bakery - Bánh ngọt từ trái tim </p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>