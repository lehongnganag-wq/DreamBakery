<div class="admin-header-flex d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fa-solid fa-cake-candles"></i> Danh sách sản phẩm kho</h2>
    <a href="/admin/sanpham/create" class="btn btn-primary" style="background-color: #ff4d7d; border: none;">
        <i class="fa-solid fa-plus"></i> Thêm bánh mới
    </a>
</div>

<div class="table-card shadow-sm p-3 bg-white" style="border-radius: 15px;">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>ẢNH</th>
                <th>TÊN BÁNH</th>
                <th>DANH MỤC</th>
                <th>GIÁ BÁN</th>
                <th>TRẠNG THÁI</th>
                <th>THAO TÁC</th>
            </tr>
        </thead>
        <tbody>
            <% products.forEach(item => { %>
            <tr>
                <td>
                    <div style="width: 50px; height: 50px; border-radius: 8px; overflow: hidden; border: 1px solid #eee; background: #f9f9f9;">
                        <img src="<%= item.HinhAnh %>" 
                             onerror="this.src='/images/default.png'" 
                             style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                </td>
                <td><strong><%= item.TenSanPham %></strong></td>
                <td>
                    <span class="badge bg-light text-dark border">
                        <%= item.DanhMuc ? item.DanhMuc.TenDanhMuc : 'Chưa phân loại' %>
                    </span>
                </td>
                <td class="text-danger fw-bold"><%= item.Gia.toLocaleString() %>đ</td>
                <td>
                    <span class="badge <%= item.SoLuong > 0 ? 'bg-success' : 'bg-danger' %>">
                        <%= item.SoLuong > 0 ? 'Còn hàng (' + item.SoLuong + ')' : 'Hết hàng' %>
                    </span>
                </td>
                <td>
                    <div class="action-btns">
                        <a href="/admin/sanpham/edit/<%= item._id %>" class="btn btn-sm btn-outline-warning border-0">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <a href="/admin/sanpham/delete/<%= item._id %>" class="btn btn-sm btn-outline-danger border-0" 
                           onclick="return confirm('Bạn có chắc chắn muốn xóa bánh này không?')">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>