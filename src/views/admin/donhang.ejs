<div class="admin-header-flex">
    <h2><i class="fa-solid fa-cart-shopping"></i> Quản lý đơn hàng khách đặt</h2>
</div>

<div class="table-card shadow">
    <table>
        <thead>
            <tr>
                <th>MÃ ĐƠN</th>
                <th>KHÁCH HÀNG</th>
                <th>NGÀY ĐẶT</th>
                <th>TỔNG TIỀN</th>
                <th>TRẠNG THÁI</th>
                <th>CHI TIẾT</th>
            </tr>
        </thead>
        <tbody>
            <% if (orders && orders.length > 0) { %>
                <% orders.forEach(order => { %>
                <tr>
                    <td>#<%= order._id.toString().slice(-6).toUpperCase() %></td>
                    
                    <td>
                        <strong><%= order.NguoiDung ? order.NguoiDung.HoTen : 'Khách vãng lai' %></strong>
                        <% if(order.NguoiDung) { %>
                            <br><small class="text-muted"><%= order.NguoiDung.Email %></small>
                        <% } %>
                    </td>
                    
                    <td><%= new Date(order.createdAt).toLocaleDateString('vi-VN') %></td>
                    
                    <td class="price" style="color: #d9534f; font-weight: bold;">
                        <%= (order.TongTien || 0).toLocaleString() %>đ
                    </td>
                    
                    <td>
                        <form action="/admin/donhang/update" method="POST" class="status-form">
                            <input type="hidden" name="orderId" value="<%= order._id %>">
                            <select name="status" onchange="this.form.submit()" class="status-select <%= order.TrangThai %>">
                                <option value="pending" <%= order.TrangThai === 'pending' ? 'selected' : '' %>>Chờ xử lý</option>
                                <option value="shipping" <%= order.TrangThai === 'shipping' ? 'selected' : '' %>>Đang giao</option>
                                <option value="delivered" <%= order.TrangThai === 'delivered' ? 'selected' : '' %>>Hoàn tất</option>
                                <option value="cancelled" <%= order.TrangThai === 'cancelled' ? 'selected' : '' %>>Đã hủy</option>
                            </select>
                        </form>
                    </td>
                    
                    <td><a href="/admin/donhang/detail/<%= order._id %>" class="btn-view">Xem chi tiết</a></td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" style="text-align: center; padding: 40px;">
                        <i class="fa-solid fa-box-open" style="font-size: 2rem; color: #ccc;"></i><br>
                        Chưa có đơn hàng nào được đặt.
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>