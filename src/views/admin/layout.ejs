<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Admin Dream Bakery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin/style.css">
</head>

<body class="admin-panel"> <div class="wrapper"> <aside class="sidebar"> <div class="sidebar-header">
            <div class="logo-icon">🍰</div>
            <div class="logo-text">
                <h1>DREAM BAKERY</h1>
                <span>ADMIN DASHBOARD</span>
            </div>
        </div>

        <div class="sidebar-menu"> <a href="/admin/dashboard" class="<%= title === 'Tổng quan Admin' ? 'active' : '' %>">
                <i class="fa-solid fa-chart-pie"></i> Tổng quan
            </a>
            <a href="/admin/sanpham">
                <i class="fa-solid fa-cake-candles"></i> Quản lý bánh
            </a>
            <a href="/admin/danhmuc">
                <i class="fa-solid fa-layer-group"></i> Danh mục
            </a>
            <a href="/admin/donhang">
                <i class="fa-solid fa-receipt"></i> Đơn hàng
            </a>
            <a href="/admin/khuyenmai">
                <i class="fa-solid fa-gift"></i> Khuyến mãi
            </a>

            <div class="menu-divider"></div>

            <a href="/" target="_blank">
                <i class="fa-solid fa-eye"></i> Xem website
            </a>
            <a href="/auth/logout">
                <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
            </a>
        </div>
    </aside>

    <div class="main-content"> <header class="top-bar">
            <div class="breadcrumb">
                <span>Trang quản trị</span> / <strong><%= title %></strong>
            </div>
            <div class="admin-user">
                <span>Chào mừng, <strong>admin!</strong></span>
            </div>
        </header>
        
        <div class="page-content">
            <%- body %>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</div>

</body>
</html>