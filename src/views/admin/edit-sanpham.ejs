<div class="container-fluid py-4">
    <div class="mb-3">
        <a href="/admin/sanpham" class="text-decoration-none text-secondary">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">
        <h3 class="mb-4" style="color: #ff4d7d;">
            <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa thông tin bánh
        </h3>
        
        <form action="/admin/sanpham/update/<%= product._id %>" method="POST" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    <input type="text" name="TenSanPham" class="form-control" value="<%= product.TenSanPham %>" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Danh mục</label>
                    <select name="DanhMuc" class="form-select" required>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat._id %>" <%= product.DanhMuc && product.DanhMuc.toString() === cat._id.toString() ? 'selected' : '' %>>
                                <%= cat.TenDanhMuc %>
                            </option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Giá bán (VNĐ)</label>
                    <input type="number" name="Gia" class="form-control" value="<%= product.Gia %>" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Số lượng trong kho</label>
                    <input type="number" name="SoLuong" class="form-control" value="<%= product.SoLuong %>" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold d-block">Hình ảnh hiện tại</label>
                <div class="mb-3 mt-2">
                    <div style="width: 160px; height: 160px; border: 2px dashed #ff4d7d; border-radius: 12px; overflow: hidden; padding: 4px; background: #fff;">
                        <img id="img-preview" src="<%= product.HinhAnh %>" 
                             onerror="this.src='/images/default.png'"
                             style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
                    </div>
                </div>
                <label class="form-label fw-bold">Chọn ảnh mới (Bỏ trống nếu giữ nguyên)</label>
                <input type="file" name="HinhAnh" class="form-control" accept="image/*" onchange="previewImage(event)">
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả sản phẩm</label>
                <textarea name="MoTa" class="form-control" rows="4"><%= product.MoTa %></textarea>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary flex-grow-1" style="background-color: #ff4d7d; border: none; padding: 12px; font-weight: bold;">
                    <i class="fa-solid fa-save"></i> Lưu thay đổi
                </button>
                <a href="/admin/sanpham" class="btn btn-light border" style="padding: 12px;">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>

<script>
    function previewImage(event) {
        const reader = new FileReader();
        reader.onload = function(){
            const output = document.getElementById('img-preview');
            output.src = reader.result;
        };
        if(event.target.files[0]) {
            reader.readAsDataURL(event.target.files[0]);
        }
    }
</script>