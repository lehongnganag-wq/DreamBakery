<div class="container mt-5">
    <div class="mb-3">
        <a href="/sanpham" class="text-decoration-none text-muted">
            <i class="fas fa-chevron-left"></i> Quay lại danh sách bánh
        </a>
    </div>

    <div class="custom-card p-4 shadow-sm" style="border-radius: 20px; background: #fff;">
        <div class="row">
            <div class="col-md-5 mb-4 mb-md-0">
                <div class="product-image-container">
                    <img src="<%= product.HinhAnh %>" 
                         alt="<%= product.TenSanPham %>" 
                         class="img-fluid" 
                         style="width: 100%; height: 450px; object-fit: cover; border-radius: 15px; border: 1px solid #f0f0f0;">
                </div>
            </div>
            
            <div class="col-md-7">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/sanpham" style="color: #ff6f61;">Cửa hàng</a></li>
                        <li class="breadcrumb-item active"><%= product.DanhMuc ? product.DanhMuc.TenDanhMuc : 'Bánh tươi' %></li>
                    </ol>
                </nav>

                <h1 class="order-title mb-2" style="color: #4a2c2a; font-weight: 700;"><%= product.TenSanPham %></h1>
                
                <div class="d-flex align-items-center mb-3">
                    <span class="price h2 mb-0" style="color: #ff6f61; font-weight: bold;">
                        <%= product.Gia.toLocaleString() %> VNĐ
                    </span>
                    <span class="badge status-done ms-3">Còn hàng</span>
                </div>

                <div class="description-box p-3 mb-4" style="background-color: #fffdf5; border-left: 4px solid #ff6f61; border-radius: 8px;">
                    <h5 style="font-size: 1rem; font-weight: 600;">Mô tả sản phẩm:</h5>
                    <p class="text-muted mb-0">
                        <%= product.MoTa || "Những chiếc bánh ngọt ngào được làm thủ công tỉ mỉ với nguyên liệu cao cấp, đảm bảo mang đến hương vị tuyệt vời nhất cho bạn." %>
                    </p>
                </div>

                <form action="/giohang/add/<%= product._id %>" method="POST" class="mt-4">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <label for="quantity" class="form-label mb-0">Số lượng:</label>
                        </div>
                        <div class="col-auto">
                            <input type="number" name="quantity" id="quantity" 
                                   class="form-control text-center" 
                                   value="1" min="1" 
                                   style="width: 80px; border-radius: 10px; border: 1px solid #ddd;">
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-checkout pulse-button py-3 px-5 w-100" style="font-size: 1.1rem; letter-spacing: 1px;">
                            <i class="fas fa-cart-plus me-2"></i> THÊM VÀO GIỎ HÀNG
                        </button>
                    </div>
                </form>

                <div class="mt-5 border-top pt-3">
                    <div class="row text-center text-muted" style="font-size: 0.9rem;">
                        <div class="col-4">
                            <i class="fas fa-truck mb-2 d-block" style="color: #ff6f61;"></i>
                            Giao hàng nhanh
                        </div>
                        <div class="col-4">
                            <i class="fas fa-utensils mb-2 d-block" style="color: #ff6f61;"></i>
                            Tươi mới mỗi ngày
                        </div>
                        <div class="col-4">
                            <i class="fas fa-shield-alt mb-2 d-block" style="color: #ff6f61;"></i>
                            An toàn vệ sinh
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>