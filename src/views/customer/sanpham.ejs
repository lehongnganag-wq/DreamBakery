<div class="container mt-5">
    <h2 class="text-center mb-5 fw-bold" style="color: #ff4d7d;">🍰 Danh sách bánh tươi mỗi ngày 🍰</h2>

    <div class="row">
        <aside class="col-md-3 mb-4">
            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-header bg-white fw-bold py-3" style="border-radius: 15px 15px 0 0;">
                    <i class="fa-solid fa-list"></i> DANH MỤC BÁNH
                </div>
                <div class="list-group list-group-flush">
                    <a href="/sanpham" class="list-group-item list-group-item-action <%= !currentCategory ? 'active' : '' %>">
                        Tất cả bánh
                    </a>
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach(cat => { %>
                            <a href="/sanpham?loai=<%= cat._id %>" 
                               class="list-group-item list-group-item-action <%= (currentCategory && currentCategory.toString() === cat._id.toString()) ? 'active' : '' %>">
                                <%= cat.TenDanhMuc %>
                            </a>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </aside>

        <section class="col-md-9">
            <div class="row">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(item => { %>
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm border-0 product-card" style="border-radius: 15px; transition: 0.3s; overflow: hidden;">
                                
                                <div style="height: 200px; overflow: hidden; background: #f8f9fa;">
                                    <% 
                                        let hinhAnhPath = item.HinhAnh;
                                        // Nếu trong DB đã có sẵn "/images/", ta không thêm vào nữa
                                        if (!hinhAnhPath.startsWith('/images/') && !hinhAnhPath.startsWith('http')) {
                                            hinhAnhPath = '/images/' + hinhAnhPath;
                                        }
                                    %>
                                    <img src="<%= hinhAnhPath %>" 
                                         class="card-img p-2" 
                                         alt="<%= item.TenSanPham %>"
                                         style="width: 100%; height: 100%; object-fit: cover; border-radius: 20px;"
                                         onerror="this.src='/images/default.png'">
                                </div>
                                
                                <div class="card-body text-center d-flex flex-column">
                                    <h6 class="fw-bold text-dark"><%= item.TenSanPham %></h6>
                                    <p class="text-danger fw-bold mb-3"><%= item.Gia.toLocaleString('vi-VN') %> VNĐ</p>
                                    
                                    <div class="d-grid gap-2 mt-auto">
                                        <a href="/sanpham/detail/<%= item._id %>" class="btn btn-outline-secondary btn-sm" style="border-radius: 10px;">
                                            Xem chi tiết
                                        </a>
                                        <form action="/giohang/add" method="POST">
                                            <input type="hidden" name="productId" value="<%= item._id %>">
                                            <button type="submit" class="btn btn-primary btn-sm w-100" style="background-color: #ff4d7d; border: none; border-radius: 10px;">
                                                Thêm vào giỏ
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <img src="https://cdn-icons-png.flaticon.com/512/2769/2769339.png" width="80" class="mb-3 opacity-50">
                        <p class="text-muted fs-5">Hiện chưa có bánh nào trong danh mục này.</p>
                    </div>
                <% } %>
            </div>
        </section>
    </div>
</div>

<style>
    .list-group-item.active {
        background-color: #ff4d7d !important;
        border-color: #ff4d7d !important;
    }
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>